@startuml mpc_loop
title EnergyPilot — MPC Rolling Horizon Loop

skinparam defaultFontSize 13

start

:Initialise state\n(soc_bat, soc_ev, temp_in);

repeat
    :Observe real values at t=0\n(price_buy, price_sell, pv, load, temp_out);

    :Build ForecastParams\n— t=0: real observations (std=0)\n— t>0: distributions from forecast model;

    :Sample ForecastTrajectory\nover horizon [t, t+T];

    :Rebuild entities with\ncurrent state as initial conditions;

    :Formulate MILP\n——————————————\nVariables: x_bat, x_ev, x_hp, p_buy, p_sell\nStates:    soc_bat, soc_ev, temp_in\nObjective: min Σ price_buy·p_buy − price_sell·p_sell\nBalance:   p_buy − p_sell = load + x_hp + x_ev + x_bat − gen\nDynamics:  SoC and temperature updates\nConstraints: bounds + EV deadline;

    :Solve MILP (HiGHS via scipy.milp);

    if (feasible?) then (yes)
        :Apply first timestep decisions\nx_bat[0], x_ev[0], x_hp[0];
        :Advance state\nsoc_bat, soc_ev, temp_in;
    else (no)
        :Log failure\nkeep state;
    endif

    :t = t + 1;

repeat while (t < T_total)

:Output results and plots;

stop
@enduml
