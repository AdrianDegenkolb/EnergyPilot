@startuml mpc_loop
title EnergyPilot — MPC Rolling Horizon Loop

skinparam defaultFontSize 13

start

:Build TimeSeries\n(sensor + forecaster per signal);

:Build OptimizationComponents\n(BatteryModel, EVModel, HeatPumpModel);

:Build PhysicalEntities\n(sensor + model + actuator per device);

repeat

    :Observe all TimeSeries\n— sensor.read() → append history\n— invalidate forecast cache;

    :Observe all PhysicalEntities\n— sensor.read() → model.set_initial_state(value);

    :HouseholdOptimizationProblem.solve(T_h, dt)\n——————————————————————\nForecasts: price_buy, price_sell, load, gen\nVariables: x_bat, x_ev, x_hp, p_buy, p_sell\nStates:    soc_bat, soc_ev, temp_in\nObjective: min Σ price_buy·p_buy − price_sell·p_sell\nBalance:   p_buy − p_sell = load + x_hp + x_ev + x_bat − gen\nDynamics:  SoC and temperature transitions\nConstraints: bounds + EV deadline + comfort;

    :Solve MILP (HiGHS via scipy.milp);

    if (feasible?) then (yes)
        :For each PhysicalEntity:\ncommand = model.extract_command(result)\nactuator.execute(command)\n→ SyntheticState.step(command)\n→ advances SoC / temperature;
        :Record MPCStep\n(step index + HouseholdResult);
    else (no)
        :Log failure — skip step;
    endif

    :t = t + 1;

repeat while (t < T_total)

:plot_results(history, dt);

stop
@enduml
