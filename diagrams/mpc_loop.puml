@startuml mpc_loop
title EnergyPilot — MPC Rolling Horizon Loop

skinparam defaultFontSize 13

start

:Precompute signal trajectories\nas TimeSeriesData objects\n(price_buy, price_sell, load, gen, temp_out);

:Build TimeSeries per signal\n(SyntheticExternalState sensor + forecaster);

:Build OptimizationComponents\n(BatteryModel, EVModel, HeatPumpModel);

:Build PhysicalEntities\n(SyntheticState sensor + model + SyntheticActuator);

repeat

    :Capture current timestamp\nfrom Time singleton;

    :Observe all TimeSeries\n— SyntheticExternalState.read() → get_value_at(t)\n— append to _history → invalidate forecast cache;

    :Forecast all TimeSeries\n— resample _history at dt intervals\n— forecaster(history, T, dt) → cache;

    :Observe all PhysicalEntities\n— sensor.read() → model.set_initial_state(value);

    :HouseholdOptimizationProblem.solve(T_h, dt)\n——————————————————————\nForecasts: price_buy, price_sell, load, gen\nVariables: x_bat, x_ev, x_hp, p_buy, p_sell\nStates:    soc_bat, soc_ev, temp_in\nObjective: min Σ price_buy·p_buy − price_sell·p_sell\nBalance:   p_buy − p_sell = load + x_hp + x_ev + x_bat − gen\nDynamics:  SoC and temperature transitions\nConstraints: bounds + EV deadline + comfort;

    :Solve MILP (HiGHS via scipy.milp);

    if (feasible?) then (yes)
        :For each PhysicalEntity:\npower = extract_optimal_power_setpoint(result)\nnext_state = extract_expected_next_step_state(result)\nactuator.execute(power, next_state)\n→ SyntheticState.set(next_state);
        :Record MPCStep\n(step + timestamp + HouseholdResult);
    else (no)
        :Log failure — skip step;
    endif

    :Advance time: Time.set(t + dt);

repeat while (t < T_total)

:For each forecasting mode:\nplot_results(history, dt)\nplot_forecast_comparison(histories, dt);

stop
@enduml
