@startuml energy_model
title EnergyPilot — Optimization Components

skinparam defaultFontSize 13
skinparam rectangleFontSize 12
skinparam arrowFontSize 11

rectangle "External Grid" as grid #LightBlue {
    rectangle "p_buy^t\n[€ price_buy^t]" as buy
    rectangle "p_sell^t\n[€ price_sell^t]" as sell
}

rectangle "Household" as house #LightYellow {
    rectangle "PV Generation\ngen^t  (TimeSeries forecast)" as gen #Gold
    rectangle "Base Load\nload^t  (TimeSeries forecast)" as load #Pink

    rectangle "Battery\nx_bat^t ∈ [−dis_max, ch_max]\nsoc_bat^t ∈ [soc_min, cap]" as bat #LightGreen
    rectangle "Electric Vehicle\nx_ev^t ∈ [−dis_max, ch_max]\nsoc_ev^{T*} ≥ target_soc" as ev #LightGreen
    rectangle "Heat Pump\nx_hp^t ∈ [0, p_max]\ntemp^t ∈ [t_min, t_max]" as hp #Orange
}

rectangle "Energy Balance\np_buy^t − p_sell^t =\nload^t + x_hp^t + x_ev^t + x_bat^t − gen^t" as balance #Lavender

grid --> balance : p_buy^t
balance --> grid : p_sell^t
gen  --> balance : gen^t
load --> balance : load^t
bat  --> balance : x_bat^t
ev   --> balance : x_ev^t
hp   --> balance : x_hp^t
@enduml
