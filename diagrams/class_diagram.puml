@startuml class_diagram
title EnergyPilot — Class Structure

skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam packageFontSize 13
skinparam packageBackgroundColor #FAFAFA
skinparam packageBorderColor #AAAAAA

' ─────────────────────────────────────────────
package "real_world_interfaces" {
    abstract class Sensor<T> {
        +{abstract} read(): T
    }

    abstract class Actuator<T> {
        +{abstract} execute(command: T)
    }
}

' ─────────────────────────────────────────────
package "synthetic" {
    class SyntheticState {
        -value: float
        -dt: float
        -update_fn: Callable | None
        +read(): float
        +set(value: float)
        +step(power: float)
        +make_sensor(): SyntheticSensor
        +make_sensor_actuator(): tuple
    }

    class SyntheticSensor {
        +read(): float
    }

    class SyntheticActuator {
        +execute(command: float)
    }

    SyntheticSensor --|> Sensor
    SyntheticActuator --|> Actuator
    SyntheticState ..> SyntheticSensor : creates
    SyntheticState ..> SyntheticActuator : creates
    SyntheticSensor --> SyntheticState : reads
    SyntheticActuator --> SyntheticState : steps
}

' ─────────────────────────────────────────────
package "forecasting" {
    abstract class SeriesForecaster {
        +{abstract} forecast(history, T, dt): ndarray
    }

    class TimeSeries {
        -sensor: Sensor[float]
        -forecaster: SeriesForecaster
        -history: deque[float]
        +observe(): float
        +forecast(T, dt): ndarray
        +latest: float
    }

    TimeSeries --> Sensor
    TimeSeries --> SeriesForecaster
}

' ─────────────────────────────────────────────
package "optimization.milp" {
    abstract class OptimizationComponent {
        +{abstract} register(reg, T)
        +{abstract} contribute(reg, constraints, objective, lb, ub, T, dt)
        +{abstract} net_power(n, t): tuple
        +{abstract} set_initial_state(value: float)
        +{abstract} extract_command(result): float
    }

    class BatteryModel {
        +capacity, soc_init, soc_min: float
        +charge_max, discharge_max: float
        +efficiency: float
    }

    class EVModel {
        +capacity, soc_init: float
        +charge_max, discharge_max: float
        +target_soc: float
        +target_timestep: int
        +efficiency: float
    }

    class HeatPumpModel {
        +temp_init, max_power: float
        +C_therm, lambda_, cop_eta: float
        +temp_min, temp_max: ndarray
        -temp_out_series: TimeSeries
    }

    class PhysicalEntity {
        +sensor: Sensor[float]
        +model: OptimizationComponent
        +actuator: Actuator
        +observe(): float
        +act(result): float
    }

    class HouseholdOptimizationProblem {
        -components: list[OptimizationComponent]
        -price_buy, price_sell: TimeSeries
        -load, gen: TimeSeries
        +solve(T, dt): HouseholdResult
    }

    class HouseholdResult {
        +success: bool
        +total_cost: float
        +p_buy, p_sell: ndarray
        +price_buy, price_sell: ndarray
        +load, gen: ndarray
        +decisions: dict
        +states: dict
    }

    BatteryModel --|> OptimizationComponent
    EVModel --|> OptimizationComponent
    HeatPumpModel --|> OptimizationComponent
    HeatPumpModel --> TimeSeries : temp_out_series
    PhysicalEntity --> Sensor
    PhysicalEntity --> OptimizationComponent
    PhysicalEntity --> Actuator
    HouseholdOptimizationProblem o-- OptimizationComponent
    HouseholdOptimizationProblem --> TimeSeries
    HouseholdOptimizationProblem ..> HouseholdResult : returns
}

' ─────────────────────────────────────────────
package "optimization.mpc" {
    class MPC {
        +entities: list[PhysicalEntity]
        +household: HouseholdOptimizationProblem
        -price_buy, price_sell: TimeSeries
        -load, gen: TimeSeries
        -extra_series: list[TimeSeries]
        +T_horizon: int
        +dt: float
        +run(T_total): MPCHistory
        #_step(step, T_h): MPCStep | None
    }

    class SyntheticMPC {
        -signal_driver: Callable[[int], None]
        #_step(step, T_h): MPCStep | None
    }

    class MPCStep {
        +step: int
        +result: HouseholdResult
    }

    class MPCHistory {
        +steps: list[MPCStep]
        +append(step)
    }

    SyntheticMPC --|> MPC
    MPC o-- PhysicalEntity
    MPC --> HouseholdOptimizationProblem
    MPC --> TimeSeries
    MPC ..> MPCHistory : returns
    MPCHistory o-- MPCStep
    MPCStep --> HouseholdResult
}

@enduml
