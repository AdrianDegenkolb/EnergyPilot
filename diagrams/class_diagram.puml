@startuml class_diagram
title EnergyPilot — Class Structure

skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam packageFontSize 13
skinparam packageBackgroundColor #FAFAFA
skinparam packageBorderColor #AAAAAA

' ─────────────────────────────────────────────
package "real_world_interfaces" {
    abstract class Sensor<T> {
        +{abstract} read(): T
    }

    abstract class Actuator<T, S> {
        +{abstract} execute(action: T, expected_next_state: S)
    }
}

' ─────────────────────────────────────────────
package "real_world_interfaces.synthetic" {
    class SyntheticState {
        -_value: float
        +read(): float
        +set(value: float)
        +make_sensor(): SyntheticSensor
        +make_sensor_actuator(): tuple
    }

    class SyntheticExternalState {
        -_data: TimeSeriesData
        +read(): float
        +make_sensor(): SyntheticSensor
    }

    class SyntheticSensor {
        +read(): float
    }

    class SyntheticActuator {
        +execute(command: float, expected_next_state: float)
    }

    SyntheticSensor --|> Sensor
    SyntheticActuator --|> Actuator
    SyntheticState ..> SyntheticSensor : creates
    SyntheticState ..> SyntheticActuator : creates
    SyntheticSensor --> SyntheticState : reads
    SyntheticActuator --> SyntheticState : sets
    SyntheticExternalState ..> SyntheticSensor : creates
    SyntheticExternalState --> TimeSeriesData : reads
}

' ─────────────────────────────────────────────
package "forecasting" {
    class Time <<singleton>> {
        +get(): datetime
        +set(t: datetime)
        +{static} get_instance(): Time
    }

    abstract class SeriesForecaster {
        +{abstract} forecast(history, T, dt: timedelta): ndarray
        #_pin(mean, current): ndarray
    }

    class TimeSeriesData {
        -_points: SortedList
        +add_point(timestamp, value)
        +get_value_at(timestamp): float
        +trim_oldest(max_size)
        +points: list
    }

    class TimeSeries {
        -_sensor: Sensor[float]
        -_forecaster: SeriesForecaster
        -_history: TimeSeriesData
        -_max_history: int
        +observe(): float
        +add_measurement(timestamp, value)
        +forecast(T, dt: timedelta): ndarray
        +get_value_at(timestamp): float
        +latest: float
        +history: list
    }

    class LookupForecaster {
        -_data: TimeSeriesData
        +forecast(history, T, dt): ndarray
    }

    class ConstantForecaster {
        +forecast(history, T, dt): ndarray
    }

    TimeSeries --> Sensor
    TimeSeries --> SeriesForecaster
    TimeSeries *-- TimeSeriesData : _history
    LookupForecaster --|> SeriesForecaster
    ConstantForecaster --|> SeriesForecaster
    LookupForecaster --> TimeSeriesData
    LookupForecaster --> Time
}

' ─────────────────────────────────────────────
package "optimization.milp" {
    abstract class OptimizationComponent {
        +id: UUID
        +{abstract} register(reg, T)
        +{abstract} contribute(reg, constraints, objective, lb, ub, T, dt: timedelta)
        +{abstract} net_power(n, t): tuple
        +{abstract} set_initial_state(value: float)
        +{abstract} extract_optimal_power_setpoint(result): float
        +extract_expected_next_step_state(result): float
    }

    class BatteryModel {
        +capacity, soc_min: float
        +charge_max, discharge_max: float
        +efficiency: float
        +soc_init: float | None
    }

    class EVModel {
        +capacity, soc_min: float
        +charge_max, discharge_max: float
        +target_soc: float | None
        +target_timestep: int | None
        +efficiency: float
        +soc_init: float | None
    }

    class HeatPumpModel {
        +temp_min, temp_max: ndarray
        +max_power, C_therm, lambda_, cop_eta: float
        +temp_init: float | None
        -_temp_out_series: TimeSeries
    }

    class PhysicalEntity {
        +sensor: Sensor[float]
        +model: OptimizationComponent
        +actuator: Actuator
        +observe(): float
        +act(result): float
    }

    class HouseholdOptimizationProblem {
        -_components: list[OptimizationComponent]
        -_price_buy, _price_sell: TimeSeries
        -_load, _gen: TimeSeries
        +solve(T, dt: timedelta): HouseholdResult
    }

    class HouseholdResult {
        +success: bool
        +total_cost: float
        +message: str
        +p_buy, p_sell: ndarray
        +price_buy, price_sell: ndarray
        +load, gen: ndarray
        +variables: dict
    }

    BatteryModel --|> OptimizationComponent
    EVModel --|> OptimizationComponent
    HeatPumpModel --|> OptimizationComponent
    HeatPumpModel --> TimeSeries : temp_out_series
    PhysicalEntity --> Sensor
    PhysicalEntity --> OptimizationComponent
    PhysicalEntity --> Actuator
    HouseholdOptimizationProblem o-- OptimizationComponent
    HouseholdOptimizationProblem --> TimeSeries
    HouseholdOptimizationProblem ..> HouseholdResult : returns
}

' ─────────────────────────────────────────────
package "optimization.mpc" {
    class MPC {
        +entities: list[PhysicalEntity]
        +household: HouseholdOptimizationProblem
        -_price_buy, _price_sell: TimeSeries
        -_load, _gen: TimeSeries
        -_extra_series: list[TimeSeries]
        +T_horizon: int
        +dt: timedelta
        +run(T_total, fast_forward): MPCHistory
        #_step(step, T_h): MPCStep | None
    }

    class MPCStep {
        +step: int
        +timestamp: datetime
        +optimization_problem: HouseholdOptimizationProblem
        +result: HouseholdResult
    }

    class MPCHistory {
        +steps: list[MPCStep]
        +append(step)
        +step_cost(i: int): float
        +cumulative_cost(): ndarray
    }

    MPC o-- PhysicalEntity
    MPC --> HouseholdOptimizationProblem
    MPC --> TimeSeries
    MPC ..> MPCHistory : returns
    MPCHistory o-- MPCStep
    MPCStep --> HouseholdResult
}

@enduml
